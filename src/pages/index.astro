---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { organizationSchema } from '../lib/schema';

const allFilms = await getCollection('films');
const featuredFilms = allFilms
  .filter(f => f.data.featured)
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const allTeam = await getCollection('team');
const featuredTeam = allTeam
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  title="Independent Film Agency"
  description="MakArtz Films is an independent film agency based in Winter Springs, FL. We develop, produce, and champion uncompromising independent cinema."
  ogType="website"
  schema={organizationSchema}
>

  <!-- SECTION 1: HERO -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="https://picsum.photos/id/1062/1920/1080"
        alt=""
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__content">
      <p class="eyebrow">Winter Springs, FL · Est. 2014</p>
      <h1 class="display hero__headline">
        Cinema That<br />
        <em>Refuses</em><br />
        Compromise.
      </h1>
      <p class="body-large hero__subline">
        We develop, produce, and champion independent films<br />
        that tell the stories no one else will.
      </p>
      <div class="hero__ctas">
        <a href="/films" class="btn btn--primary">View Our Films</a>
        <a href="/submit" class="btn btn--ghost">Submit a Project</a>
      </div>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <span class="caption">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- SECTION 2: MARQUEE -->
  <div class="marquee-wrap" aria-hidden="true">
    <div class="marquee-track">
      <span>A Quiet Storm</span>
      <span class="marquee-dot">·</span>
      <span>The Last Crossing</span>
      <span class="marquee-dot">·</span>
      <span>The Weight of Salt</span>
      <span class="marquee-dot">·</span>
      <span>Inland</span>
      <span class="marquee-dot">·</span>
      <span>Still Water</span>
      <span class="marquee-dot">·</span>
      <span>Common Ground</span>
      <span class="marquee-dot">·</span>
      <span>Sundance · Tribeca · SXSW · Cannes · AFI · Hot Docs</span>
      <span class="marquee-dot">·</span>
      <span>A Quiet Storm</span>
      <span class="marquee-dot">·</span>
      <span>The Last Crossing</span>
      <span class="marquee-dot">·</span>
      <span>The Weight of Salt</span>
      <span class="marquee-dot">·</span>
      <span>Inland</span>
      <span class="marquee-dot">·</span>
      <span>Still Water</span>
      <span class="marquee-dot">·</span>
      <span>Common Ground</span>
      <span class="marquee-dot">·</span>
      <span>Sundance · Tribeca · SXSW · Cannes · AFI · Hot Docs</span>
      <span class="marquee-dot">·</span>
    </div>
  </div>

  <!-- SECTION 3: FEATURED FILMS -->
  <section class="films-section section-pad films-section--padded section--light">
    <div class="container">
      <div class="section-header reveal">
        <p class="eyebrow">Selected Works</p>
        <h2 class="heading-1">Recent Films</h2>
      </div>
      <div class="films-grid reveal-grid">
        {featuredFilms.map(film => (
          <article class="film-card">
            <a href={`/films/${film.slug}`} class="film-card__link">
              <div class="poster-container film-card__poster">
                <img
                  src={film.data.posterImage}
                  alt={`${film.data.title} — directed by ${film.data.director}`}
                  width="600"
                  height="900"
                  loading="lazy"
                  class="film-image"
                />
                <div class="film-card__tags" aria-hidden="true">
                  {film.data.genre.map(g => (
                    <span class="film-card__tag">{g}</span>
                  ))}
                </div>
              </div>
              <div class="film-card__info">
                <span class="caption">{film.data.year} · {film.data.director}</span>
                <h3 class="heading-3 film-card__title">{film.data.title}</h3>
                <p class="caption film-card__logline">{film.data.logline}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
      <div class="section-cta reveal">
        <a href="/films" class="btn btn--ghost-dark">View All Films</a>
      </div>
    </div>
  </section>

  <!-- SECTION 4: MISSION -->
  <section class="mission-section section-pad" style="background: var(--ink2);">
    <div class="container mission-grid">
      <div class="mission-quote reveal">
        <div style="width: 48px; height: 2px; background: var(--sienna); margin-bottom: var(--space-3);" aria-hidden="true"></div>
        <blockquote class="mission-blockquote">
          <p class="display mission-blockquote__text">
            "We exist for the films<br />
            that couldn't exist<br />
            without us."
          </p>
          <cite class="eyebrow mission-blockquote__cite">
            — Jacob Schwartz, Founder
          </cite>
        </blockquote>
      </div>
      <div class="mission-body reveal">
        <p class="eyebrow mission-eyebrow">Our Mission</p>
        <p class="body-large mission-lead">
          MakArtz Films was founded on a single conviction: that independent cinema — truly independent, uncompromising, filmmaker-driven cinema — requires advocates who understand both the art and the business, and who refuse to let one consume the other.
        </p>
        <p class="body mission-copy">
          We work with directors at every stage — from the first draft of a script through the last screening in a festival run. We develop projects, structure financing, produce films, and shepherd them into the world through careful distribution strategy. We don't acquire finished films. We build them.
        </p>
        <p class="body mission-copy">
          Our slate spans documentary and narrative, debut features and established voices, American stories and international co-productions. What our films share is a refusal to be anything other than exactly what they are.
        </p>
        <a href="/about" class="btn btn--ghost">About MakArtz Films</a>
      </div>
    </div>
  </section>

  <!-- SECTION 5: STATS STRIP -->
  <div class="stats-strip" aria-label="MakArtz Films by the numbers" style="background: var(--ink2); border-top: 1px solid var(--border-dark); border-bottom: 1px solid var(--border-dark); padding: var(--space-12) 0;">
    <div class="container stats-grid">
      <div class="stat reveal">
        <span class="display stat__number" style="font-size: clamp(3rem, 7vw, 5.5rem); color: var(--sienna); letter-spacing: -0.02em;">18</span>
        <span class="eyebrow">Features Produced</span>
      </div>
      <div class="stat reveal">
        <span class="display stat__number" style="font-size: clamp(3rem, 7vw, 5.5rem); color: var(--sienna); letter-spacing: -0.02em;">47</span>
        <span class="eyebrow">Festival Awards</span>
      </div>
      <div class="stat reveal">
        <span class="display stat__number" style="font-size: clamp(3rem, 7vw, 5.5rem); color: var(--sienna); letter-spacing: -0.02em;">23</span>
        <span class="eyebrow">Countries</span>
      </div>
      <div class="stat reveal">
        <span class="display stat__number" style="font-size: clamp(3rem, 7vw, 5.5rem); color: var(--sienna); letter-spacing: -0.02em;">11</span>
        <span class="eyebrow">Years</span>
      </div>
    </div>
  </div>

  <!-- SECTION 6: TEAM TEASER -->
  <section class="team-section section-pad section--light">
    <div class="container">
      <div class="section-header reveal">
        <p class="eyebrow">The People</p>
        <h2 class="heading-1">Our Team</h2>
      </div>
      <div class="team-grid reveal-grid">
        {featuredTeam.map(member => (
          <div class="team-card">
            <div class="team-card__photo">
              <img
                src={member.data.headshotImage}
                alt={member.data.headshotAlt ?? `${member.data.name} — ${member.data.title}`}
                width="400"
                height="400"
                loading="lazy"
                class="film-image"
              />
            </div>
            <div class="team-card__info">
              <p class="eyebrow">{member.data.title}</p>
              <h3 class="heading-3 team-card__name">{member.data.name}</h3>
              <p class="body team-card__bio">{member.data.bio}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="section-cta reveal">
        <a href="/team" class="btn btn--ghost-dark">Meet the Full Team</a>
      </div>
    </div>
  </section>

  <!-- SECTION 7: PRESS QUOTES -->
  <section class="press-section" style="background: var(--ink2); border-top: 1px solid var(--border-dark);">
    <div class="container">
      <div class="film-strip-accent reveal" aria-hidden="true">
        <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
      </div>
      <p class="eyebrow reveal press-eyebrow">Press &amp; Recognition</p>
      <div class="press-grid reveal-grid">
        <blockquote class="press-card">
          <p class="press-card__quote">"One of the most consistently vital forces in American independent cinema today."</p>
          <cite class="press-card__source">— Variety</cite>
        </blockquote>
        <blockquote class="press-card">
          <p class="press-card__quote">"MakArtz Films makes space for the difficult, the quiet, and the unsaid — exactly the films that need champions."</p>
          <cite class="press-card__source">— The Hollywood Reporter</cite>
        </blockquote>
        <blockquote class="press-card">
          <p class="press-card__quote">"A track record at the major festivals that any studio would envy."</p>
          <cite class="press-card__source">— IndieWire</cite>
        </blockquote>
        <blockquote class="press-card">
          <p class="press-card__quote">"They find the films that feel impossible and make them happen anyway."</p>
          <cite class="press-card__source">— Film Comment</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- SECTION 8: CONTACT CTA -->
  <section class="cta-section section--light" style="background: var(--parchment); border-top: 1px solid var(--border-light); padding: var(--space-16) 0; text-align: center;">
    <div class="container cta-inner">
      <div class="reveal">
        <div style="width: 48px; height: 2px; background: var(--sienna); margin: 0 auto var(--space-4);" aria-hidden="true"></div>
        <p class="eyebrow cta-eyebrow">Work With Us</p>
        <h2 class="heading-1 cta-heading" style="color: var(--text-dark);">
          Got a film that<br />needs a home?
        </h2>
        <p class="body-large cta-body" style="color: var(--text-dark-body);">
          We accept submissions year-round. If you have a project in development, production, or post — and you believe in what it is — we want to hear from you.
        </p>
        <div class="cta-buttons">
          <a href="/submit" class="btn btn--primary">Submit a Project</a>
          <a href="/contact" class="btn btn--ghost-dark">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ─────────────────────────────────────────
   SHARED LAYOUT UTILITIES
───────────────────────────────────────── */
.section-pad { padding: var(--space-16) 0; }
.container { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); }
.section-header { margin-bottom: var(--space-8); }
.section-header .eyebrow { margin-bottom: var(--space-1); }
.section-cta { margin-top: var(--space-8); }

.films-section { background: var(--parchment); }
.films-section--padded { padding-top: var(--space-24); }
.films-section .section-header .heading-1 { color: var(--text-dark); }

.team-section { background: var(--parchment); }
.team-section .section-header .heading-1 { color: var(--text-dark); }

/* ─────────────────────────────────────────
   SECTION 1: HERO
───────────────────────────────────────── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: flex-end;
  padding-bottom: var(--space-16);
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero__bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: grayscale(0.4) brightness(0.6);
  transform: scale(1.04);
  transition: transform 8s var(--ease-cinematic);
}

.hero:hover .hero__bg img {
  transform: scale(1.0);
}

.hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to top,
    rgba(24, 18, 16, 1) 0%,
    rgba(24, 18, 16, 0.72) 38%,
    rgba(24, 18, 16, 0.18) 68%,
    rgba(24, 18, 16, 0.06) 100%
  );
}

.hero__content {
  position: relative;
  z-index: 3;
  padding: 0 var(--space-8);
  padding-bottom: var(--space-4);
  max-width: 1000px;
}

.hero__headline {
  margin: var(--space-2) 0;
  color: var(--text-primary);
}

.hero__headline em {
  font-style: italic;
  color: var(--sienna);
}

.hero__subline {
  margin-bottom: var(--space-4);
  max-width: 52ch;
  color: var(--text-body);
}

.hero__ctas {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.hero__scroll {
  position: absolute;
  bottom: var(--space-4);
  right: var(--space-6);
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
  opacity: 0.5;
}

.hero__scroll-line {
  width: 1px;
  height: 48px;
  background: var(--text-muted);
  animation: scrollPulse 2s var(--ease-cinematic) infinite;
}

@keyframes scrollPulse {
  0%   { transform: scaleY(0); transform-origin: top; }
  50%  { transform: scaleY(1); transform-origin: top; }
  51%  { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}

@media (max-width: 600px) {
  .hero__content { padding: 0 var(--space-4); }
}

/* ─────────────────────────────────────────
   SECTION 2: MARQUEE
───────────────────────────────────────── */
.marquee-wrap {
  background: var(--sienna);
  overflow: hidden;
  padding: 0.75rem 0;
  white-space: nowrap;
}

.marquee-track {
  display: inline-flex;
  gap: var(--space-4);
  animation: marqueeScroll 40s linear infinite;
}

.marquee-track span {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--parchment);
}

.marquee-dot {
  opacity: 0.5;
}

@keyframes marqueeScroll {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

@media (prefers-reduced-motion: reduce) {
  .marquee-track { animation: none; }
}

/* ─────────────────────────────────────────
   SECTION 3: FEATURED FILMS
───────────────────────────────────────── */
.films-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4);
}

@media (max-width: 900px) {
  .films-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .films-grid { grid-template-columns: 1fr; }
}

.film-card {
  background: #fff;
  border: none;
  box-shadow: 0 2px 12px rgba(24,18,16,0.08), 0 1px 3px rgba(24,18,16,0.06);
  transition: box-shadow var(--duration-base) var(--ease-cinematic),
              transform var(--duration-base) var(--ease-cinematic);
}
.film-card:hover {
  box-shadow: 0 12px 40px rgba(24,18,16,0.16), 0 4px 12px rgba(24,18,16,0.10);
  transform: translateY(-3px);
}
.film-card__link { text-decoration: none; display: block; }

.film-card__poster { position: relative; }

.film-card__tags {
  position: absolute;
  bottom: var(--space-2);
  left: var(--space-2);
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.film-card__tag {
  font-family: var(--font-sans);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: rgba(24, 18, 16, 0.75);
  color: var(--parchment2);
  padding: 0.25rem 0.5rem;
  border: none;
}

.film-card__info {
  padding: var(--space-3);
  background: #fff;
}

/* Caption/metadata override inside film cards on parchment section */
.films-section .film-card .caption {
  color: var(--text-dark-muted);
}

.film-card__title {
  color: var(--text-dark);
  margin: var(--space-1) 0;
  transition: color var(--duration-fast) var(--ease-cinematic);
}

.film-card__link:hover .film-card__title { color: var(--sienna); }

.film-card__logline {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ─────────────────────────────────────────
   SECTION 4: MISSION
───────────────────────────────────────── */
/* Mission background set via inline style on the section element */

.mission-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: center;
}

@media (max-width: 900px) {
  .mission-grid {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
}

.mission-blockquote { color: var(--text-primary); }

.mission-blockquote__text {
  font-size: clamp(2.2rem, 4.5vw, 4.2rem);
  line-height: 1.0;
  letter-spacing: -0.01em;
}

.mission-blockquote__cite {
  margin-top: var(--space-3);
  display: block;
}

.mission-eyebrow { margin-bottom: var(--space-2); }
.mission-lead { margin-bottom: var(--space-3); }
.mission-copy { margin-bottom: var(--space-3); }
.mission-copy:last-of-type { margin-bottom: var(--space-6); }

/* ─────────────────────────────────────────
   SECTION 5: STATS STRIP
───────────────────────────────────────── */
/* Stats background/border set via inline style on the element */
.stats-strip {
  padding: var(--space-8) 0;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-4);
  text-align: center;
}

@media (max-width: 700px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-1);
}

/* Stat numbers — size and tracking */
.stat__number {
  font-size: clamp(3rem, 7vw, 5.5rem);
  letter-spacing: -0.02em;
}

/* ─────────────────────────────────────────
   SECTION 6: TEAM TEASER
───────────────────────────────────────── */
.team-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

@media (max-width: 900px) {
  .team-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .team-grid { grid-template-columns: 1fr; }
}

.team-card__photo {
  overflow: hidden;
  margin-bottom: var(--space-3);
  aspect-ratio: 1 / 1;
  background: var(--parchment2);
}

.team-card__photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.team-card__name {
  color: var(--text-dark);
  margin-top: var(--space-1);
}

.team-card__bio {
  margin-top: var(--space-2);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  color: var(--text-dark-body);
}

/* ─────────────────────────────────────────
   SECTION 7: PRESS QUOTES
───────────────────────────────────────── */
/* Press background/border set via inline style on the section element */
.press-section {
  padding: var(--space-12) 0;
}

.press-eyebrow {
  margin-bottom: var(--space-6);
  text-align: center;
}

.press-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-4);
}

@media (max-width: 1000px) {
  .press-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 600px) {
  .press-grid { grid-template-columns: 1fr; }
}

.press-card {
  padding: var(--space-4);
  border: 1px solid var(--border-dark);
  background: rgba(244, 234, 213, 0.03);
  position: relative;
  transition: border-color var(--duration-base) var(--ease-cinematic),
              background var(--duration-base) var(--ease-cinematic);
}

.press-card:hover {
  border-color: var(--sienna);
  background: rgba(244, 234, 213, 0.055);
}

.press-card__quote {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  font-style: italic;
  color: var(--text-primary);
  line-height: 1.65;
  margin-bottom: var(--space-3);
}

.press-card__source {
  font-family: var(--font-sans);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--sienna);
  font-style: normal;
}

.press-card::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--sienna);
  transition: width var(--duration-base) var(--ease-cinematic);
}

.press-card:hover::after { width: 100%; }

/* ─────────────────────────────────────────
   SECTION 8: CONTACT CTA
───────────────────────────────────────── */
/* CTA background/border/padding set via inline style on the section element */
.cta-section {
  text-align: center;
}

.cta-inner {
  max-width: 640px;
}

.cta-rule {
  margin: 0 auto var(--space-3);
}

.cta-eyebrow { margin-bottom: var(--space-2); }

.cta-heading {
  color: var(--cream);
  margin-bottom: var(--space-3);
}

.cta-body { margin-bottom: var(--space-6); }

.cta-buttons {
  display: flex;
  gap: var(--space-2);
  justify-content: center;
  flex-wrap: wrap;
}

/* Film strip accent — press section decoration */
.film-strip-accent {
  display: flex;
  gap: 6px;
  justify-content: center;
  margin-bottom: var(--space-4);
}
.film-strip-accent span {
  display: block;
  width: 18px;
  height: 12px;
  border: 1px solid var(--border-dark);
  opacity: 0.4;
}

/* Section header heading color on light sections */
.films-section .section-header .heading-1,
.team-section .section-header .heading-1 {
  color: var(--text-dark);
}
</style>
