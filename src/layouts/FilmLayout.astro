---
import BaseLayout from './BaseLayout.astro';
import { movieSchema } from '../lib/schema';

interface Props {
  title: string;
  director: string;
  year: number;
  genre: string[];
  description: string;
  posterImage: string;
  slug: string;
  imdbUrl?: string;
  streamingLinks?: { label: string; url: string }[];
  runtime?: string;
  festivalHistory?: string[];
}

const {
  title,
  director,
  year,
  genre,
  description,
  posterImage,
  slug,
  imdbUrl,
  streamingLinks,
  runtime,
  festivalHistory,
} = Astro.props;

const schema = movieSchema({
  title,
  director,
  year,
  genre,
  description,
  posterImage,
  slug,
  imdbUrl,
  streamingLinks,
});
---

<BaseLayout
  title={title}
  description={description}
  ogImage={posterImage}
  ogType="video.movie"
  schema={schema}
>
  <article class="film-article">
    <div class="film-layout">
      <aside class="film-poster">
        <div class="poster-container">
          <img
            src={posterImage}
            alt={`${title} — poster`}
            width="400"
            height="600"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </aside>

      <div class="film-info">
        <header class="film-header">
          <p class="eyebrow">{year} &middot; {genre.join(', ')}</p>
          <h1 class="display film-title">{title}</h1>
          <p class="body-large film-description">{description}</p>
        </header>

        <dl class="film-meta">
          <div class="meta-item">
            <dt class="eyebrow">Director</dt>
            <dd class="body">{director}</dd>
          </div>
          {runtime && (
            <div class="meta-item">
              <dt class="eyebrow">Runtime</dt>
              <dd class="body">{runtime}</dd>
            </div>
          )}
        </dl>

        {streamingLinks && streamingLinks.length > 0 && (
          <div class="film-streaming">
            <p class="eyebrow" style="margin-bottom: var(--space-2);">Watch</p>
            <div class="streaming-links">
              {streamingLinks.map((link) => (
                <a
                  href={link.url}
                  class="streaming-btn"
                  target="_blank"
                  rel="noopener noreferrer"
                >{link.label}</a>
              ))}
            </div>
          </div>
        )}

        {festivalHistory && festivalHistory.length > 0 && (
          <div class="film-festivals">
            <p class="eyebrow" style="margin-bottom: var(--space-2);">Festival History</p>
            <ul class="festival-list" role="list">
              {festivalHistory.map((entry) => (
                <li class="caption festival-item">{entry}</li>
              ))}
            </ul>
          </div>
        )}

        {imdbUrl && (
          <a
            href={imdbUrl}
            class="imdb-link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${title} on IMDb`}
          >View on IMDb</a>
        )}
      </div>
    </div>

    <div class="film-body prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
.film-article {
  padding-top: calc(var(--space-16) + var(--space-6));
  padding-bottom: var(--space-16);
  max-width: 1280px;
  margin: 0 auto;
  padding-left: var(--space-6);
  padding-right: var(--space-6);
}

.film-layout {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: var(--space-12);
  margin-bottom: var(--space-12);
}

.film-poster {
  flex-shrink: 0;
}

.film-header {
  margin-bottom: var(--space-6);
}

.film-title {
  margin: var(--space-2) 0 var(--space-3);
}

.film-meta {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-bottom: var(--space-6);
  padding: var(--space-4);
  border: 1px solid var(--border);
}

.meta-item dt { margin-bottom: var(--space-1); }

.film-streaming,
.film-festivals {
  margin-bottom: var(--space-6);
}

.streaming-links {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.streaming-btn {
  font-family: var(--font-sans);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--cream);
  text-decoration: none;
  border: 1px solid var(--border);
  padding: 0.5rem 1rem;
  transition: border-color var(--duration-fast), background var(--duration-fast);
}

.streaming-btn:hover {
  border-color: var(--red);
  background: rgba(200, 53, 42, 0.1);
}

.festival-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.festival-item::before {
  content: '— ';
  color: var(--red);
}

.imdb-link {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color var(--duration-fast);
}

.imdb-link:hover { color: var(--cream); }

.film-body {
  max-width: 72ch;
}

@media (max-width: 800px) {
  .film-layout {
    grid-template-columns: 1fr;
  }
  .film-poster {
    max-width: 280px;
  }
}
</style>
