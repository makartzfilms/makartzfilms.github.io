---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Col 1: Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-wordmark">MakArtz Films</a>
        <p class="footer-tagline">Independent Cinema. Uncompromising Vision.</p>
        <p class="footer-desc">An independent film agency based in Winter Springs, FL.</p>
      </div>

      <!-- Col 2: Explore -->
      <nav class="footer-col" aria-label="Explore">
        <p class="footer-col-heading">Explore</p>
        <ul role="list">
          <li><a href="/films">Films</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/team">Team</a></li>
        </ul>
      </nav>

      <!-- Col 3: Work With Us -->
      <nav class="footer-col" aria-label="Work with us">
        <p class="footer-col-heading">Work With Us</p>
        <ul role="list">
          <li><a href="/submit">Submit a Project</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <!-- Col 4: Read -->
      <nav class="footer-col" aria-label="Reading">
        <p class="footer-col-heading">Read</p>
        <ul role="list">
          <li><a href="/journal">Journal</a></li>
          <li><a href="/notes">From the Cutting Room</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {currentYear} MakArtz Films &middot; All rights reserved
      </p>
      <a href="/privacy" class="footer-privacy">Privacy Policy</a>
      <div class="footer-social">
        <a
          href="#"
          aria-label="Instagram"
          class="social-link"
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a
          href="#"
          aria-label="Vimeo"
          class="social-link"
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M21 7.5c-.2 4-2.9 9.5-8.1 16.5C7.6 17.6 5 12.5 5 9c0-3.5 1.6-5 3.5-5 1.7 0 2.7 1 4 4.5.5-3.5 2-5.5 4.5-5.5 2 0 4 2.5 4 4.5z"/>
          </svg>
        </a>
        <a
          href="#"
          aria-label="IMDb"
          class="social-link"
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <rect x="2" y="6" width="20" height="12" rx="2"/>
            <text x="4.5" y="15" font-size="7" font-weight="800" fill="#050505" font-family="sans-serif">IMDb</text>
          </svg>
        </a>
        <a
          href="#"
          aria-label="LinkedIn"
          class="social-link"
          rel="noopener noreferrer"
          target="_blank"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: var(--ink);
  border-top: 1px solid var(--border-dark);
  margin-top: 0;
  padding: var(--space-12) 0 var(--space-6);
}

.footer-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-6);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: var(--space-8);
  margin-bottom: var(--space-8);
}

.footer-wordmark {
  font-family: var(--font-serif);
  font-size: 1.25rem;
  font-weight: 500;
  color: var(--text-primary);
  text-decoration: none;
  display: block;
  margin-bottom: var(--space-2);
}

.footer-tagline {
  font-family: var(--font-serif);
  font-size: 0.95rem;
  font-style: italic;
  color: var(--text-primary);
  margin-bottom: var(--space-2);
}

.footer-desc {
  font-family: var(--font-sans);
  font-size: 0.8rem;
  line-height: 1.6;
  color: var(--text-muted);
  max-width: 28ch;
}

.footer-col-heading {
  font-family: var(--font-sans);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--sienna);
  margin-bottom: var(--space-3);
}

.footer-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.footer-col a {
  font-family: var(--font-sans);
  font-size: 0.875rem;
  color: var(--text-muted);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-cinematic);
}

.footer-col a:hover { color: var(--text-primary); }

.footer-bottom {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  padding-top: var(--space-4);
  border-top: 1px solid var(--border-dark);
  flex-wrap: wrap;
}

.footer-copy {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-right: auto;
}

.footer-privacy {
  font-family: var(--font-sans);
  font-size: 0.75rem;
  color: var(--text-muted);
  text-decoration: none;
  transition: color var(--duration-fast);
}

.footer-privacy:hover { color: var(--text-primary); }

.footer-social {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.social-link {
  color: var(--text-muted);
  transition: color var(--duration-fast) var(--ease-cinematic);
  display: flex;
  align-items: center;
}

.social-link:hover { color: var(--text-primary); }

@media (max-width: 900px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
  .footer-brand {
    grid-column: 1 / -1;
  }
}

@media (max-width: 700px) {
  .footer-grid {
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: 40px;
  }
  .site-footer {
    padding: var(--space-8) var(--space-3) var(--space-6);
  }
  .footer-bottom {
    flex-direction: column;
    gap: var(--space-2);
    text-align: center;
    padding: var(--space-4) 0 0;
  }
}
</style>
