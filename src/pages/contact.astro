---
import BaseLayout from '../layouts/BaseLayout.astro';

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact MakArtz Films',
  url: 'https://makartzfilms.com/contact',
  description: 'Get in touch with MakArtz Films — an independent film agency in Los Angeles and New York.',
};
---
<BaseLayout
  title="Contact"
  description="Contact MakArtz Films — reach our independent film agency in Los Angeles and New York. Get in touch for production inquiries, press, and general questions."
  schema={contactPageSchema}
>
  <section style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding-top:var(--space-16);">
    <p style="color:var(--muted);font-family:var(--font-sans);">— Contact page coming soon —</p>
  </section>
</BaseLayout>
