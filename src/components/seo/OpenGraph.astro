---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonicalURL: string;
  noindex?: boolean;
}
const {
  title,
  description,
  ogImage = '/og-default.jpg',
  ogType = 'website',
  canonicalURL,
  noindex = false,
} = Astro.props;
const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : `https://makartzfilms.com${ogImage}`;
---

{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:title" content={`${title} — MakArtz Films`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="MakArtz Films" />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={`${title} — MakArtz Films`} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />
