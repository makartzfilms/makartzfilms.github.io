</style>

<script>
function initCarousel(grid: HTMLElement | null, dots: HTMLElement[]) {
  if (!grid || dots.length === 0) return;

  const cards = Array.from(grid.children) as HTMLElement[];

  function setActive(index: number) {
    dots.forEach((dot, i) => dot.classList.toggle('active', i === index));
  }

  setActive(0);

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      const card = cards[i];
      if (!card) return;
      const scrollTarget = card.offsetLeft - (grid.clientWidth - card.offsetWidth) / 2;
      grid.scrollTo({ left: scrollTarget, behavior: 'smooth' });
    });
  });

  grid.addEventListener('scroll', () => {
    const center = grid.scrollLeft + grid.clientWidth / 2;
    let activeIndex = 0;
    let minDist = Infinity;
    cards.forEach((card, i) => {
      const dist = Math.abs((card.offsetLeft + card.offsetWidth / 2) - center);
      if (dist < minDist) { minDist = dist; activeIndex = i; }
    });
    setActive(activeIndex);
  }, { passive: true });
}

const filmsGrid = document.querySelector<HTMLElement>('.films-grid');
const filmsDots = [...document.querySelectorAll<HTMLElement>('.films-section .carousel-hint span')];

const teamGrid = document.querySelector<HTMLElement>('.team-grid');
const teamDots = [...document.querySelectorAll<HTMLElement>('.team-section .carousel-hint span')];

const pressGrid = document.querySelector<HTMLElement>('.press-grid');
const pressDots = [...document.querySelectorAll<HTMLElement>('.press-pagination span')];

initCarousel(filmsGrid, filmsDots);
initCarousel(teamGrid, teamDots);
initCarousel(pressGrid, pressDots);
</script>
