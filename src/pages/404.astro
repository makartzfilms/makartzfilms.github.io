---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found"
  description="The page you are looking for could not be found."
  noindex={true}
>
  <section style="min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding-top:var(--space-16);gap:var(--space-4);">
    <p class="eyebrow">404</p>
    <h1 class="heading-1" style="color:var(--cream);">Page Not Found</h1>
    <p style="color:var(--muted);font-family:var(--font-sans);">The reel seems to have snapped.</p>
    <a href="/" style="color:var(--red);font-family:var(--font-sans);font-size:0.875rem;text-decoration:underline;">Return home</a>
  </section>
</BaseLayout>
