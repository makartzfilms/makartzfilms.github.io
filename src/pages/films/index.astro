---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allFilms = await getCollection('films');
const films = allFilms.sort((a, b) => b.data.year - a.data.year);

const allGenres = [...new Set(films.flatMap(f => f.data.genre))].sort();
---

<BaseLayout
  title="Our Films — MakArtz Films"
  description="Explore the MakArtz Films catalog — a curated selection of independent and arthouse films we have developed, produced, and championed."
>

  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content reveal">
        <p class="eyebrow">The Slate</p>
        <h1 class="display">Our Films</h1>
        <p class="body-large page-hero__sub">
          Every film in our catalog was developed from the ground up — built with the filmmaker, for the audience it deserves.
        </p>
      </div>
    </div>
  </section>

  <!-- FILTER + GRID -->
  <section class="catalog-section section-container">
    <div class="container">

      <!-- Genre filters -->
      <div class="filters reveal" id="genre-filters">
        <button class="filter-pill active" data-filter="all">All</button>
        {allGenres.map(genre => (
          <button class="filter-pill" data-filter={genre}>{genre}</button>
        ))}
      </div>

      <!-- Film grid -->
      <div class="catalog-grid" id="catalog-grid">
        {films.map(film => (
          <article class="film-card reveal" data-genre={JSON.stringify(film.data.genre)}>
            <a href={`/films/${film.slug}`} class="film-card__link">
              <div class="film-card__poster">
                <img
                  src={film.data.posterImage}
                  alt={`${film.data.title} — directed by ${film.data.director}`}
                  width="600"
                  height="900"
                  loading="lazy"
                  class="film-card__img"
                />
                <div class="film-card__tags" aria-hidden="true">
                  {film.data.genre.map(g => (
                    <span class="film-card__tag">{g}</span>
                  ))}
                </div>
              </div>
              <div class="film-card__info">
                <span class="caption">{film.data.year} · {film.data.director}</span>
                <h3 class="heading-3 film-card__title">{film.data.title}</h3>
                <p class="caption film-card__logline">{film.data.logline}</p>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- No results -->
      <div class="no-results" id="no-results" style="display:none;">
        <p class="body-large">No films match this genre. Try another filter.</p>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filters = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const cards = document.querySelectorAll<HTMLElement>('.film-card');
    const noResults = document.getElementById('no-results');

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        filters.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const genre = btn.dataset.filter;
        let visible = 0;

        cards.forEach(card => {
          const genres: string[] = JSON.parse(card.dataset.genre || '[]');
          const show = genre === 'all' || genres.includes(genre!);
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (noResults) {
          noResults.style.display = visible === 0 ? 'block' : 'none';
        }
      });
    });
  });
</script>

<style>
  /* ── Page Hero ── */
  .page-hero {
    background: #ffffff;
    padding: var(--space-24) 0 var(--space-12);
  }
  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }
  .page-hero__content {
    max-width: 700px;
  }
  .page-hero__content .display {
    color: var(--text-dark);
    margin: var(--space-2) 0;
  }
  .page-hero__sub {
    color: var(--text-dark-muted);
    max-width: 52ch;
  }

  /* ── Catalog Section ── */
  .catalog-section {
    background: var(--ink2);
    padding-bottom: var(--space-16);
  }

  /* ── Filters ── */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .filter-pill {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.5rem 1.25rem;
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border-dark);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-pill:hover {
    color: var(--text-primary);
    border-color: rgba(255,255,255,0.25);
  }

  .filter-pill.active {
    background: var(--sienna);
    color: #ffffff;
    border-color: var(--sienna);
  }

  /* ── Grid ── */
  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 900px) {
    .catalog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .catalog-grid { grid-template-columns: 1fr; }
  }

  /* ── Film Card ── */
  .film-card {
    background: var(--ink);
    border: 1px solid var(--border-dark);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }
  .film-card:hover {
    border-color: rgba(255,255,255,0.15);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    transform: translateY(-2px);
  }

  .film-card__link {
    text-decoration: none;
    display: block;
    height: 100%;
  }

  .film-card__poster {
    position: relative;
    overflow: hidden;
  }

  .film-card__img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: 2 / 3;
    transition: transform 0.4s ease;
  }
  .film-card:hover .film-card__img {
    transform: scale(1.03);
  }

  .film-card__tags {
    position: absolute;
    bottom: var(--space-2);
    left: var(--space-2);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .film-card__tag {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: rgba(24, 18, 16, 0.75);
    color: var(--parchment2);
    padding: 0.25rem 0.5rem;
    border: none;
  }

  .film-card__info {
    padding: var(--space-3);
  }

  .film-card__info .caption {
    color: var(--text-muted);
  }

  .film-card__title {
    color: var(--text-primary);
    margin: var(--space-1) 0;
    transition: color 0.2s ease;
  }
  .film-card__link:hover .film-card__title {
    color: var(--sienna);
  }

  .film-card__logline {
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── No Results ── */
  .no-results {
    text-align: center;
    padding: var(--space-12) 0;
    color: var(--muted);
  }
</style>
