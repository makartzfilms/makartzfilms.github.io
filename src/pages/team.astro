---
import BaseLayout from '../layouts/BaseLayout.astro';

const teamPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Team — MakArtz Films',
  url: 'https://makartzfilms.com/team',
  description: 'Meet the people behind MakArtz Films — our team of film industry professionals based in Los Angeles and New York.',
};
---
<BaseLayout
  title="Team"
  description="Meet the team behind MakArtz Films — film industry professionals dedicated to independent and arthouse cinema in Los Angeles and New York."
  schema={teamPageSchema}
>
  <section style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding-top:var(--space-16);">
    <p style="color:var(--muted);font-family:var(--font-sans);">— Team page coming soon —</p>
  </section>
</BaseLayout>
