---
import BaseLayout from '../layouts/BaseLayout.astro';

const aboutPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About MakArtz Films',
  url: 'https://makartzfilms.com/about',
  mainEntity: {
    '@type': 'Organization',
    name: 'MakArtz Films',
    url: 'https://makartzfilms.com',
    description: 'An independent film agency based in Los Angeles and New York, dedicated to developing, producing, and championing uncompromising independent cinema.',
  },
};
---
<BaseLayout
  title="About"
  description="MakArtz Films is an independent film agency based in Los Angeles and New York. Learn about our mission to develop and champion uncompromising independent cinema."
  schema={aboutPageSchema}
>
  <section style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding-top:var(--space-16);">
    <p style="color:var(--muted);font-family:var(--font-sans);">— About page coming soon —</p>
  </section>
</BaseLayout>
